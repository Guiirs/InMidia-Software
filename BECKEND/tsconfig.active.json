    "src/modules/propostas-internas/repositories/**/*",
    "src/modules/biweeks/biWeeks.routes.ts",
    "src/modules/biweeks/controllers/**/*",
    "src/modules/biweeks/repositories/**/*",
    "src/modules/biweeks/services/**/*",
