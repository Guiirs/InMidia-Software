{
  "name": "api",
  "version": "1.0.0",
  "main": "dist/shared/infra/http/server.js",
  "scripts": {
    "build": "tsc",
    "start": "cross-env NODE_ENV=production node -r module-alias/register dist/shared/infra/http/server.js",
    "dev": "cross-env NODE_ENV=development nodemon --exec ts-node src/shared/infra/http/server.ts",
    "dev:redis": "powershell -ExecutionPolicy Bypass -File ./start-with-redis.ps1",
    "redis:stop": "powershell -ExecutionPolicy Bypass -File ./stop-redis.ps1",
    "dev:old": "cross-env NODE_ENV=development ts-node-dev --respawn --transpile-only --ignore-watch node_modules src/shared/infra/http/server.ts",
    "test": "cross-env NODE_ENV=test jest --config=jest.config.js --testTimeout=10000 --passWithNoTests",
    "test:contracts": "cross-env NODE_ENV=test jest --config=jest.config.js --testPathPattern=contracts --testTimeout=10000 --passWithNoTests",
    "test:integration": "cross-env NODE_ENV=test jest --config=jest.config.js --testPathPattern=integration --testTimeout=30000 --passWithNoTests --runInBand",
    "ci:contracts": "cross-env NODE_ENV=test jest --config=jest.config.js --testPathPattern=\"(contracts|integration)\" --testTimeout=30000 --passWithNoTests --runInBand --ci",
    "migrate:disponivel": "ts-node scripts/migrate-placa-disponivel.ts",
    "migrate:disponivel:dry": "ts-node scripts/migrate-placa-disponivel.ts --dry-run",
    "test:migrate": "cross-env NODE_ENV=test npx knex migrate:latest",
    "migrate": "knex migrate:latest",
    "migrate:alugueis": "ts-node scripts/migrate-alugueis-to-unified-period.ts",
    "migrate:alugueis:dry": "ts-node scripts/migrate-alugueis-to-unified-period.ts --dry-run",
    "migrate:fields": "ts-node scripts/migrate-database-suffix.ts",
    "migrate:fields:dry": "ts-node scripts/migrate-database-suffix.ts --dry-run",
    "public-api:keygen": "node scripts/generate-public-api-key.mjs",
    "bkp": "node scripts/backupManual.js",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "typecheck:active": "tsc -p tsconfig.active.json",
    "ci:typecheck": "tsc -p tsconfig.active.json",
    "check:ts-nocheck": "node scripts/check-ts-nocheck.js",
    "check:ts-nocheck:report": "node scripts/check-ts-nocheck.js --report",
    "audit:multitenancy": "ts-node scripts/audit-multitenancy-queries.ts",
    "audit:multitenancy:report": "ts-node scripts/audit-multitenancy-queries.ts --report",
    "audit:multitenancy:json": "ts-node scripts/audit-multitenancy-queries.ts --json"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.914.0",
    "@types/cookie-parser": "^1.4.10",
    "axios": "^1.13.1",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.65.0",
    "cookie-parser": "^1.4.7",
    "cross-env": "^7.0.3",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.1.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "module-alias": "^2.2.3",
    "mongoose": "^8.19.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^3.0.1",
    "node-cron": "^4.2.1",
    "pdfkit": "^0.17.2",
    "prom-client": "^15.1.3",
    "puppeteer": "^24.29.1",
    "qrcode-terminal": "^0.12.0",
    "redis": "^4.7.1",
    "socket.io": "^4.8.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^8.3.2",
    "whatsapp-web.js": "^1.34.2",
    "winston": "^3.13.0",
    "xlsx-populate": "^1.21.0",
    "xlsx-preview": "^1.0.4",
    "zod": "^4.1.13"
  },
  "_moduleAliases": {
    "@modules": "dist/modules",
    "@shared": "dist/shared",
    "@config": "dist/config",
    "@utils": "dist/utils",
    "@database": "dist/database",
    "@scripts": "dist/scripts",
    "@models": "dist/models",
    "@middlewares": "dist/shared/infra/http/middlewares",
    "@routes": "dist/shared/infra/http/routes",
    "@validators": "dist/validators",
    "@types": "dist/types",
    "@gateway": "dist/gateway",
    "@security": "dist/security"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.5",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.10.1",
    "@types/pdfkit": "^0.17.4",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.2.3",
    "nodemon": "^3.1.11",
    "supertest": "^6.3.3",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
