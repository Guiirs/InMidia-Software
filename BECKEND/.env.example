# Arquivo: .env.example
# Este é um template para as variáveis de ambiente do BACKEND (Node.js/API).
# Copie este arquivo para .env (que deve estar no .gitignore) e preencha com seus valores.

# --- Segurança e Autenticação ---
# Chave secreta longa para assinar os tokens JWT (mínimo 64 caracteres — use um gerador seguro)
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your_super_long_and_random_jwt_secret_here_minimum_64_characters_required_in_production"

# Duração do ACCESS TOKEN (HttpOnly cookie curta duração — recomendado: 15m)
ACCESS_TOKEN_EXPIRES_IN="15m"

# Duração do REFRESH TOKEN (longa duração — armazenado hash no banco)
REFRESH_TOKEN_EXPIRES_IN="7d"

# --- Banco de Dados ---
# String de conexão do MongoDB (inclua usuário e senha em produção)
# Docker local: mongodb://mongouser:mongopassword@mongo:27017/api_db?authSource=admin
# Atlas: mongodb+srv://<user>:<password>@<cluster-url>/?appName=cluster
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster-url>/?appName=cluster"

# Credenciais do MongoDB (usadas apenas no docker-compose)
MONGO_ROOT_USERNAME="mongouser"
MONGO_ROOT_PASSWORD="change_this_strong_password_here"
MONGO_DB_NAME="api_db"

# --- Redis Cache ---
# Host do servidor Redis
REDIS_HOST=localhost
# Porta do Redis
REDIS_PORT=6379
# Senha do Redis (OBRIGATÓRIA — não deixe vazio em produção)
REDIS_PASSWORD="change_this_strong_redis_password_here"
# TTL padrão do cache em segundos (300 = 5 minutos)
CACHE_TTL=300
# URL completa do Redis (usada pelo BullMQ — inclua a senha)
# Formato: redis://:<password>@<host>:<port>
REDIS_URL="redis://:change_this_strong_redis_password_here@localhost:6379"

# --- Configurações de Ambiente ---
# URL onde o frontend está rodando (para o CORS)
FRONTEND_URL="http://localhost:5173"

# Porta em que o servidor backend irá rodar
PORT=4000

# --- Logs e Debug ---
# Habilitar logs HTTP detalhados (true/false)
LOG_HTTP=false

# Threshold para logar [HTTP] SLOW em respostas bem-sucedidas (ms)
HTTP_SLOW_MS=1000

# Habilitar logs detalhados do Gateway (true/false)
LOG_GATEWAY=false

# --- Cloudflare R2 (Armazenamento de Arquivos) ---
# O endpoint da sua conta R2
R2_ENDPOINT="https://<account_id>.r2.cloudflarestorage.com/<bucket_name>"

# Chave de Acesso (ID) do R2
R2_ACCESS_KEY_ID="your_r2_access_key_id_here"

# Chave de Acesso Secreta do R2
R2_SECRET_ACCESS_KEY="your_r2_secret_access_key_here"

# Nome do bucket R2
R2_BUCKET_NAME="name-bucket-here"

# URL pública do bucket (se configurada)
R2_PUBLIC_URL="https://pub-xxxxxxxx.r2.dev"

# --- Serviços Externos (PDF) ---
# Chave de API para o serviço PDFRest
PDF_REST_API_KEY="your_pdfrest_api_key_xxxxxxxx"

# Endpoint do serviço PDFRest
PDF_REST_ENDPOINT="https://api.pdfrest.com/pdf"

# --- WhatsApp Integration (Opcional) ---
# Habilitar/Desabilitar integração WhatsApp
WHATSAPP_ENABLED=false

# Nome do grupo WhatsApp para enviar relatórios (o sistema busca por este nome)
WHATSAPP_GROUP_NAME="Placas Disponíveis"

# Se não encontrar o grupo pelo nome, usar o primeiro grupo disponível (true/false)
WHATSAPP_USE_FIRST_GROUP=false

# Horário para envio do relatório diário (formato HH:MM)
WHATSAPP_REPORT_HOUR="09:00"

# Fuso horário para agendamento
TZ="Europe/Lisbon"

# --- Production readiness / observability ---
NODE_ENV=development
CORS_ORIGIN="http://localhost:5173"
# Legado — preferir ACCESS_TOKEN_EXPIRES_IN e REFRESH_TOKEN_EXPIRES_IN
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Prometheus metrics. Required in production.
# As credenciais do prometheus.yml devem ser configuradas como Docker secrets
# ou variáveis de ambiente seguras — nunca hardcoded no prometheus.yml
METRICS_USER="metrics_user_here"
METRICS_PASSWORD="change_this_strong_metrics_password_here"

# Operational Sync Layer.
SYNC_REDIS_ENABLED=false
SYNC_REDIS_MODE=streams
SYNC_REDIS_CHANNEL_PREFIX=sync:events
SYNC_STREAM_MAXLEN=5000
SYNC_HIGH_LAG_MS=5000
SYNC_RECONNECT_STORM_THRESHOLD=5
SYNC_METRICS_PROVIDER=memory
SYNC_DIAGNOSTICS_REDIS_ENABLED=false
SYNC_DIAGNOSTICS_REDIS_KEY_PREFIX=sync:diagnostics
SYNC_DIAGNOSTICS_TTL_MS=3600000

# --- Temporal Engine V4.1 ---
# Mantem o scheduler temporal desligado por padrao. Em test ele nunca inicia automaticamente.
TEMPORAL_SCHEDULER_ENABLED=false
TEMPORAL_SCHEDULER_CRON="0 3 * * *"
TEMPORAL_SCHEDULER_DAYS_BEFORE_END=7
# Opcional: empresa usada apenas para eventos sistemicos do cron.
TEMPORAL_SCHEDULER_SYSTEM_EMPRESA_ID=""
