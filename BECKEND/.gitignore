# =============================================================================
# BECKEND (Node.js / TypeScript / Express) — .gitignore enterprise
# =============================================================================

# ─── DEPENDÊNCIAS ─────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.pnpm-store/

# ─── BUILD ────────────────────────────────────────────────────────────────────
dist/
docs/
build/
out/
*.tsbuildinfo

# ─── VARIÁVEIS DE AMBIENTE ────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.local

# ─── LOGS ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
access.log
combined.log
error.log
all.log

# ─── RUNTIME / PIDS ───────────────────────────────────────────────────────────
pids/
*.pid
*.pid.lock
*.seed
*.heapsnapshot
.lock-wscript

# ─── CACHES ───────────────────────────────────────────────────────────────────
.cache/
.eslintcache
.npm/
.node_repl_history

# ─── ARTEFATOS DE TESTE ───────────────────────────────────────────────────────
coverage/
.nyc_output/
test-results/
playwright-report/
playwright/.cache/
__snapshots__/

# ─── BANCOS DE DADOS / DUMPS ──────────────────────────────────────────────────
*.rdb
dump.rdb
*.db
*.sqlite
*.sqlite3
*.db3

# ─── REDIS ────────────────────────────────────────────────────────────────────
redis-new/
redis-data/

# ─── UPLOADS / MÍDIA TEMPORÁRIA ───────────────────────────────────────────────
uploads/
public/uploads/
tmp-uploads/
media-tmp/

# ─── WHATSAPP / whatsapp-web.js ───────────────────────────────────────────────
.wwebjs_cache/
.wwebjs_auth/
whatsapp-session/
whatsapp-sessions/
auth_info_multi/
auth_info_baileys/

# ─── SESSÕES ──────────────────────────────────────────────────────────────────
sessions/
.session/

# ─── TEMPORÁRIOS ──────────────────────────────────────────────────────────────
tmp/
temp/
*.tmp
*.temp
*.swp
*.swo
*~

# ─── BACKUPS ──────────────────────────────────────────────────────────────────
backup-*/
backups/
_old_*/
*_backup/
*_bak/

# ─── SEGURANÇA — NUNCA COMMITAR ───────────────────────────────────────────────
*.pem
*.key
*.p12
*.pfx
*.crt
*.cert
*.der
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
secrets.json
secrets.yaml
secrets.yml

# ─── SSE / RUNTIME TEMP ───────────────────────────────────────────────────────
sse-clients/
socket-data/

# ─── IDE — VSCODE ─────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json
*.code-workspace

# ─── IDE — JETBRAINS ──────────────────────────────────────────────────────────
.idea/
*.iws
*.iml
*.ipr

# ─── UPLOADS TEMPORÁRIOS ──────────────────────────────────────────────────────
uploads/tmp/
.tmp/

# ─── BINÁRIOS LOCAIS (Redis / debug symbols) ──────────────────────────────────
*.pdb

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
ehthumbs.db
