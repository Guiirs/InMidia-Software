# =============================================================================
# INMIDIA MONOREPO — Enterprise .gitignore
# Ambientes cobertos: / (root)  |  REACT/  |  BECKEND/
# =============================================================================

# ─── DEPENDÊNCIAS ─────────────────────────────────────────────────────────────
node_modules/
**/node_modules/
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnpm-store/

# ─── BUILD / DIST ─────────────────────────────────────────────────────────────
dist/
build/
docs/
out/
.output/
**/dist/
**/build/
**/out/
dist-ssr/
storybook-static/
*.tsbuildinfo
**/*.tsbuildinfo

# ─── VARIÁVEIS DE AMBIENTE ────────────────────────────────────────────────────
# NUNCA commitar credenciais reais — apenas .env.example é permitido
.env
.env.*
**/.env
**/.env.*
!.env.example
!**/.env.example
*.local
**/*.local

# ─── LOGS ─────────────────────────────────────────────────────────────────────
logs/
**/logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
access.log
combined.log
error.log
all.log

# ─── RUNTIME / PIDS ───────────────────────────────────────────────────────────
pids/
**/pids/
*.pid
*.pid.lock
*.seed
*.heapsnapshot
.lock-wscript

# ─── CACHES ───────────────────────────────────────────────────────────────────
.cache/
**/.cache/
.vite/
**/.vite/
.turbo/
**/.turbo/
