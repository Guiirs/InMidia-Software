# ─── ARQUIVOS TEMPORÁRIOS ─────────────────────────────────────────────────────
tmp/
temp/
**/tmp/
**/temp/
*.tmp
*.temp
*.swp
*.swo
*~

# ─── BACKUPS ──────────────────────────────────────────────────────────────────
backup-*/
backups/
**/backup-*/
**/backups/
_old_*/
**/old_*/
*_backup/
*_bak/

# ─── SEGURANÇA — NUNCA COMMITAR ───────────────────────────────────────────────
*.pem
*.key
*.p12
*.pfx
*.crt
*.cert
*.der
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
*.keystore
*.jks
secrets.json
secrets.yaml
secrets.yml
**/secrets.json
**/secrets.yaml
**/secrets.yml

# ─── IDE — VSCODE ─────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json
*.code-workspace

# ─── IDE — JETBRAINS ──────────────────────────────────────────────────────────
