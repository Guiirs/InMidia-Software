**/.eslintcache
.stylelintcache
.parcel-cache
**/.parcel-cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/
.npm/
.node_repl_history
.rollup.cache/

# ─── ARTEFATOS DE TESTE ───────────────────────────────────────────────────────
coverage/
**/coverage/
.nyc_output/
**/.nyc_output/
test-results/
**/test-results/
playwright-report/
**/playwright-report/
