# Backstage Application - Environment Variables Template
# INSTRUCAO: Copie este arquivo para .env e preencha com valores reais.
# NUNCA commite o arquivo .env com credenciais reais.
# NUNCA use os valores placeholder abaixo em producao.

# --- BACKEND ---

# JWT Secret - minimo 64 caracteres aleatorios.
# Gerar com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="SUBSTITUA_POR_STRING_ALEATORIA_64_CHARS_MIN"

# JWT Expiration
JWT_EXPIRES_IN="24h"
JWT_REFRESH_EXPIRES_IN="7d"

# MongoDB - use URI do Atlas ou do seu servidor
MONGODB_URI="mongodb://localhost:27017/backstage"

# Redis
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""
REDIS_URL="redis://localhost:6379"
CACHE_TTL=300

# Porta da API
PORT=4000

# Ambiente
NODE_ENV=development

# CORS - dominio do frontend em producao
CORS_ORIGIN="http://localhost:5173"

# Storage (R2/S3 - deixe vazio para usar armazenamento local)
R2_ENDPOINT=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_FOLDER_NAME="inmidia-uploads"
STORAGE_PUBLIC_URL=""

# WhatsApp (opcional)
WHATSAPP_ENABLED=false

# Metricas (Prometheus) - obrigatorio em producao para /metrics
# Gerar com: openssl rand -base64 16
METRICS_USER="SUBSTITUA_POR_USUARIO_METRICAS"
METRICS_PASSWORD="SUBSTITUA_POR_SENHA_METRICAS"

# Monitoring local (Grafana) - obrigatorio para docker-compose.monitoring.yml
GRAFANA_ADMIN_PASSWORD="SUBSTITUA_POR_SENHA_FORTE_GRAFANA"

# Conta master de bootstrap (criada na primeira inicializacao)
# ATENCAO: Use senha forte e unica. Altere imediatamente apos o primeiro login.
MASTER_LOGIN_EMAIL="admin@SEUDOMINIO.com"
MASTER_LOGIN_USERNAME="admin"
MASTER_LOGIN_PASSWORD="SUBSTITUA_POR_SENHA_FORTE_MIN_12_CHARS"
MASTER_LOGIN_NOME="Administrador"
MASTER_EMPRESA_NOME="Minha Empresa"
MASTER_EMPRESA_CNPJ="00000000000000"

# Operational Sync Layer - Redis distribuido (COMM-4)
# Habilita Redis Pub/Sub para sincronizacao entre multiplas instancias.
# Deixe false para usar apenas buffer em memoria (modo local-only).
SYNC_REDIS_ENABLED=false

# Prefixo dos canais Redis usados pelo Sync Layer.
# Mude se este Redis for compartilhado com outros sistemas.
SYNC_REDIS_CHANNEL_PREFIX=sync:events

# Modo de operacao do Redis bus (pubsub e o unico disponivel em COMM-4).
# Redis Streams sera suportado em COMM-5.
SYNC_REDIS_MODE=pubsub

# Limite de entradas por empresa no Redis Stream (COMM-5, mode=streams).
# Valor aproximado - Redis usa MAXLEN ~ para melhor performance.
SYNC_STREAM_MAXLEN=5000

# COMM-10 diagnostics persistence and health scoring.
SYNC_HIGH_LAG_MS=5000
SYNC_RECONNECT_STORM_THRESHOLD=5
SYNC_METRICS_PROVIDER=memory
SYNC_DIAGNOSTICS_REDIS_ENABLED=false
SYNC_DIAGNOSTICS_REDIS_KEY_PREFIX=sync:diagnostics
SYNC_DIAGNOSTICS_TTL_MS=3600000

# --- FRONTEND ---
VITE_API_URL="http://localhost:4000/api/v1"
VITE_API_BASE_URL="http://localhost:4000/api/v1"
VITE_BACKEND_URL="http://localhost:4000"
VITE_R2_PUBLIC_URL=""
VITE_R2_BASE_PATH="inmidia-uploads-sistema"
VITE_UPTIMEROBOT_READONLY_KEY=""
VITE_UPTIMEROBOT_MONITOR_ID=""
