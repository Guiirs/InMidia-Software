# Frontend environment template
# Copy to .env.local for local development or configure in the hosting provider.

# API base URL. Can point to backend root or /api/v1; the app normalizes it.
VITE_API_URL="http://localhost:4000/api/v1"
VITE_API_BASE_URL="http://localhost:4000/api/v1"
VITE_BACKEND_URL="http://localhost:4000"

# Public asset base for images stored in R2/S3-compatible storage.
VITE_R2_PUBLIC_URL=""
VITE_R2_BASE_PATH="inmidia-uploads-sistema"

# Optional API status page integration.
VITE_UPTIMEROBOT_READONLY_KEY=""
VITE_UPTIMEROBOT_MONITOR_ID=""

# Inventory v4 isolated route feature flag (read-only).
VITE_FEATURE_INVENTORY_V4_ROUTE="false"

# Habilita rotas legadas em /legacy/* para diagnóstico e migração controlada.
# Quando false (padrão), todas as rotas /legacy/* redirecionam para o V4.
# Quando true, as páginas V3 ficam acessíveis via /legacy/placas, /legacy/map, etc.
VITE_ENABLE_LEGACY_PANEL="false"

# Data de depreciação definitiva do painel legado (ISO 8601).
# Após esta data, o painel legado pode ser removido com segurança.
# Usada por ferramentas de monitoramento e documentação técnica.
# Deixar vazio se a data ainda não foi definida.
VITE_LEGACY_PANEL_DEPRECATION_DATE=""
